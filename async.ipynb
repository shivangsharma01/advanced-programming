   "source": [
    "import asyncio\n",
    "\n",
    "async def task():\n",
    "    await asyncio.sleep(2)\n",
    "\n",
    "async def main():\n",
    "    asyncio.gather(\n",
    "        task(),\n",
    "        task(),\n",
    "        task()\n",
    "    )\n",
    "\n",
    "asyncio.run(main())"
   ]
  }
